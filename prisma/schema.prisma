generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Movie {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  description  String?
  genre        String // Stored as comma separated or JSON string
  language     String?
  releaseYear  Int?
  posterUrl    String?
  imdbLink     String?
  priority     String    @default("Medium") // Low, Medium, High
  status       String    @default("ToWatch") // ToWatch, Watched
  type         String    @default("movie") // movie, series, episode
  rating       Int?      // For watched movies (1-5)
  review       String?
  watchedAt    DateTime?
  rewatchCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
